{
    "manifest_version": 3,
    "name": "ClipShelf",
    "version": "0.1.0",
    "description": "Save cropped screenshots and page URLs into named groups.",
    "permissions": [
        "activeTab",
        "storage",
        "scripting",
        "unlimitedStorage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_title": "ClipShelf"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}